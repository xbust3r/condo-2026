# Environment configuration template for condo-py
# Copy this file to .env and fill in the values
# ⚠️ .env is in .gitignore — never commit real secrets

# =============================================================================
# DATABASE
# =============================================================================
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_HOST=mysql
MYSQL_DB=db_condominiums
MYSQL_PORT=3306

# =============================================================================
# JWT AUTHENTICATION (REQUIRED — app fails at boot if missing)
# =============================================================================
# Generate secrets with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
#
JWT_ACCESS_SECRET=generate_and_replace_with_32_char_random_string
JWT_REFRESH_SECRET=generate_and_replace_with_32_char_random_string

# =============================================================================
# EXTERNAL SERVICES (optional)
# =============================================================================
# BOOM_USER=zodiac-boom-tube
# BOOM_PASS=your_boom_password
# BOOM_SLUG=zodiac-panelhub
# BUCKET=stg-zodiac-panelhub
# URL_SERVICE_BOOM=https://boom-tube.confiejarvis.com
